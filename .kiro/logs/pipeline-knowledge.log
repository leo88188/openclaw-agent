[0m[49m[38;5;10m+    296[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    297[0m:[38;5;10m[49m ```sql
[0m[49m[38;5;10m+    298[0m:[38;5;10m[49m CREATE TABLE `teams` (
