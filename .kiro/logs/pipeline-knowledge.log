[0m[49m[38;5;10m+    129[0m:[38;5;10m[49m   KEY `ix_knowledge_items_category` (`category`),
[0m[49m[38;5;10m+    130[0m:[38;5;10m[49m   KEY `ix_knowledge_items_team_id` (`team_id`),
[0m[49m[38;5;10m+    131[0m:[38;5;10m[49m   KEY `ix_knowledge_items_created_at` (`created_at`)
