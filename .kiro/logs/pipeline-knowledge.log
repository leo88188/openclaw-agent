[0m[49m[38;5;10m+    330[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    331[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    332[0m:[38;5;10m[49m #### 查询场景
[0m[49m[38;5;10m+    333[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    334[0m:[38;5;10m[49m | 场景 | SQL | 命中索引 | 走缓存 | 读写比 |
[0m[49m[38;5;10m+    335[0m:[38;5;10m[49m |------|-----|---------|--------|--------|
[0m[49m[38;5;10m+    336[0m:[38;5;10m[49m | 团队成员列表 | `SELECT * FROM team_members WHERE team_id=?` | uk_team_user（前缀） | ❌ | 读多写少 |
[0m[49m[38;5;10m+    337[0m:[38;5;10m[49m | 检查成员角色 | `SELECT role FROM team_members WHERE team_id=? AND user_name=?` | uk_team_user | ❌ | 读多写少 |
[0m[49m[38;5;10m+    338[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    339[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    340[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    341[0m:[38;5;10m[49m ## 5. 事务边界
[0m[49m[38;5;10m+    342[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    343[0m:[38;5;10m[49m | 操作 | 事务范围 | 说明 |
[0m[49m[38;5;10m+    344[0m:[38;5;10m[49m |------|---------|------|
[0m[49m[38;5;10m+    345[0m:[38;5;10m[49m | 创建知识 + 向量化 | 分离 | DB 写入成功即返回；向量化异步/容错，失败不回滚 |
[0m[49m[38;5;10m+    346[0m:[38;5;10m[49m | 收藏 Skill | 同一事务 | INSERT skill_favorites + UPDATE skills SET favorite_count=favorite_count+1 |
[0m[49m[38;5;10m+    347[0m:[38;5;10m[49m | 取消收藏 | 同一事务 | DELETE skill_favorites + UPDATE skills SET favorite_count=favorite_count-1 |
[0m[49m[38;5;10m+    348[0m:[38;5;10m[49m | 删除团队 | 同一事务 | DELETE team_members + DELETE teams |
[0m[49m[38;5;10m+    349[0m:[38;5;10m[49m | 导入元数据 | 同一事务 | DELETE 旧数据 + BATCH INSERT 新数据（同一 db_name+table_name） |
[0m[49m[38;5;10m+    350[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    351[0m:[38;5;10m[49m ### 最终一致性场景
[0m[49m[38;5;10m+    352[0m:[38;5;10m[49m - 向量化：知识创建后异步向量化，短暂窗口内搜索不到新内容，可接受
[0m[49m[38;5;10m+    353[0m:[38;5;10m[49m - 缓存：写操作后主动删缓存，极端情况下有 TTL 窗口的脏读
[0m[49m[38;5;10m+    354[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    355[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    356[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    357[0m:[38;5;10m[49m ## 6. Redis 缓存设计
[0m[49m[38;5;10m+    358[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    359[0m:[38;5;10m[49m ### 6.1 Key 命名规则
[0m[49m[38;5;10m+    360[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    361[0m:[38;5;10m[49m 格式：`knowledge:{模块}:{维度}:{参数}`
[0m[49m[38;5;10m+    362[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    363[0m:[38;5;10m[49m | Key 模式 | 示例 | 用途 | TTL | 失效策略 | 脏读容忍 |
[0m[49m[38;5;10m+    364[0m:[38;5;10m[49m |----------|------|------|-----|---------|---------|
[0m[49m[38;5;10m+    365[0m:[38;5;10m[49m | `knowledge:list:{page}:{size}:{category}` | `knowledge:list:1:20:` | 知识列表 | 300s | 创建/更新/删除时 DEL `knowledge:list:*` | 5min |
[0m[49m[38;5;10m+    366[0m:[38;5;10m[49m | `knowledge:detail:{id}` | `knowledge:detail:42` | 知识详情 | 600s | 更新/删除时 DEL | 不容忍 |
[0m[49m[38;5;10m+    367[0m:[38;5;10m[49m | `skills:list:{page}:{category}:{is_public}` | `skills:list:1::1` | Skill 列表 | 300s | 创建/更新/删除时 DEL `skills:list:*` | 5min |
[0m[49m[38;5;10m+    368[0m:[38;5;10m[49m | `skills:detail:{id}` | `skills:detail:7` | Skill 详情 | 600s | 更新/删除时 DEL | 不容忍 |
[0m[49m[38;5;10m+    369[0m:[38;5;10m[49m | `dashboard:stats` | `dashboard:stats` | 仪表盘统计 | 120s | TTL 自然过期 | 2min |
[0m[49m[38;5;10m+    370[0m:[38;5;10m[49m | `metadata:tables:{db_name}` | `metadata:tables:knowledge` | 表列表 | 1800s | 导入时 DEL | 30min |
[0m[49m[38;5;10m+    371[0m:[38;5;10m[49m | `metadata:table:{db_name}:{table_name}` | `metadata:table:knowledge:skills` | 表详情 | 1800s | 导入时 DEL | 30min |
[0m[49m[38;5;10m+    372[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    373[0m:[38;5;10m[49m ### 6.2 TTL 策略
[0m[49m[38;5;10m+    374[0m:[38;5;10m[49m - 高频变更数据（知识列表、Skill 列表）：5 分钟
[0m[49m[38;5;10m+    375[0m:[38;5;10m[49m - 低频变更数据（元数据）：30 分钟
[0m[49m[38;5;10m+    376[0m:[38;5;10m[49m - 统计数据：2 分钟（接受短暂脏读）
[0m[49m[38;5;10m+    377[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    378[0m:[38;5;10m[49m ### 6.3 失效策略
[0m[49m[38;5;10m+    379[0m:[38;5;10m[49m - 写操作（创建/更新/删除）→ 主动删除相关缓存 Key
[0m[49m[38;5;10m+    380[0m:[38;5;10m[49m - 统计数据 → TTL 自然过期（不值得主动失效）
[0m[49m[38;5;10m+    381[0m:[38;5;10m[49m - 列表缓存 → 使用 `SCAN` + `DEL` 批量失效（避免 `KEYS *`）
[0m[49m[38;5;10m+    382[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    383[0m:[38;5;10m[49m ### 缓存防护
[0m[49m[38;5;10m+    384[0m:[38;5;10m[49m - 缓存穿透：查询不存在的 ID 时，缓存空值 60s
[0m[49m[38;5;10m+    385[0m:[38;5;10m[49m - 缓存雪崩：TTL 加随机偏移（±30s）
[0m[49m[38;5;10m+    386[0m:[38;5;10m[49m - 缓存击穿：热点 Key 使用 singleflight 模式（同一 Key 并发只查一次 DB）
[0m[49m[38;5;10m+    387[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    388[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    389[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    390[0m:[38;5;10m[49m ## 7. 一致性模型
[0m[49m[38;5;10m+    391[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    392[0m:[38;5;10m[49m | 场景 | 一致性级别 | 说明 |
[0m[49m[38;5;10m+    393[0m:[38;5;10m[49m |------|-----------|------|
[0m[49m[38;5;10m+    394[0m:[38;5;10m[49m | 知识 CRUD | 强一致 | 写入 DB 后立即可读 |
[0m[49m[38;5;10m+    395[0m:[38;5;10m[49m | 列表缓存 | 最终一致 | 写操作后主动删缓存，但并发请求可能读到旧缓存 |
[0m[49m[38;5;10m+    396[0m:[38;5;10m[49m | 向量搜索 | 最终一致 | 向量化异步执行，新内容有短暂搜索不到的窗口 |
[0m[49m[38;5;10m+    397[0m:[38;5;10m[49m | 收藏计数 | 强一致 | 同一事务内更新 |
[0m[49m[38;5;10m+    398[0m:[38;5;10m[49m | 统计数据 | 最终一致 | 2 分钟 TTL，接受脏读 |
[0m[49m[38;5;10m+    399[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    400[0m:[38;5;10m[49m ---
[0m[49m[38;5;10m+    401[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    402[0m:[38;5;10m[49m ## 8. 迁移方案
[0m[49m[38;5;10m+    403[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    404[0m:[38;5;10m[49m ### 当前状态 vs 设计差异
[0m[49m[38;5;10m+    405[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    406[0m:[38;5;10m[49m 以下是实际数据库缺失的约束和索引，需要补充：
[0m[49m[38;5;10m+    407[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    408[0m:[38;5;10m[49m ```sql
[0m[49m[38;5;10m+    409[0m:[38;5;10m[49m -- 1. knowledge_items 补充 created_at 索引
[0m[49m[38;5;10m+    410[0m:[38;5;10m[49m ALTER TABLE knowledge_items ADD INDEX ix_knowledge_items_created_at (created_at);
[0m[49m[38;5;10m+    411[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    412[0m:[38;5;10m[49m -- 2. skills 补充 is_public 索引
[0m[49m[38;5;10m+    413[0m:[38;5;10m[49m ALTER TABLE skills ADD INDEX ix_skills_is_public (is_public);
[0m[49m[38;5;10m+    414[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    415[0m:[38;5;10m[49m -- 3. db_metadata 补充复合索引
[0m[49m[38;5;10m+    416[0m:[38;5;10m[49m ALTER TABLE db_metadata ADD INDEX ix_db_metadata_db_table (db_name, table_name);
[0m[49m[38;5;10m+    417[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    418[0m:[38;5;10m[49m -- 4. team_members 补充唯一约束
[0m[49m[38;5;10m+    419[0m:[38;5;10m[49m ALTER TABLE team_members ADD UNIQUE KEY uk_team_user (team_id, user_name);
[0m[49m[38;5;10m+    420[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    421[0m:[38;5;10m[49m -- 5. skill_favorites 补充唯一约束
[0m[49m[38;5;10m+    422[0m:[38;5;10m[49m ALTER TABLE skill_favorites ADD UNIQUE KEY uk_skill_user (skill_id, user_name);
[0m[49m[38;5;10m+    423[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    424[0m:[38;5;10m[49m -- 6. knowledge_items 补充 updated_at 自动更新（实际表缺失 ON UPDATE）
[0m[49m[38;5;10m+    425[0m:[38;5;10m[49m ALTER TABLE knowledge_items MODIFY updated_at datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP;
[0m[49m[38;5;10m+    426[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    427[0m:[38;5;10m[49m -- 7. skills 补充 updated_at 自动更新
[0m[49m[38;5;10m+    428[0m:[38;5;10m[49m ALTER TABLE skills MODIFY updated_at datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP;
[0m[49m[38;5;10m+    429[0m:[38;5;10m[49m ```
[0m[49m[38;5;10m+    430[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    431[0m:[38;5;10m[49m ### 回滚方案
[0m[49m[38;5;10m+    432[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    433[0m:[38;5;10m[49m ```sql
[0m[49m[38;5;10m+    434[0m:[38;5;10m[49m -- 回滚上述迁移
[0m[49m[38;5;10m+    435[0m:[38;5;10m[49m ALTER TABLE knowledge_items DROP INDEX ix_knowledge_items_created_at;
