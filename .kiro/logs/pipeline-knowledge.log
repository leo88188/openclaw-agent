[0m[49m[38;5;10m+    437[0m:[38;5;10m[49m ALTER TABLE db_metadata DROP INDEX ix_db_metadata_db_table;
[0m[49m[38;5;10m+    438[0m:[38;5;10m[49m ALTER TABLE team_members DROP INDEX uk_team_user;
[0m[49m[38;5;10m+    439[0m:[38;5;10m[49m ALTER TABLE skill_favorites DROP INDEX uk_skill_user;
[0m[49m[38;5;10m+    440[0m:[38;5;10m[49m ```
