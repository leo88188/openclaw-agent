[0m[49m[38;5;10m+    319[0m:[38;5;10m[49m 
[0m[49m[38;5;10m+    320[0m:[38;5;10m[49m ```sql
[0m[49m[38;5;10m+    321[0m:[38;5;10m[49m CREATE TABLE `team_members` (
[0m[49m[38;5;10m+    322[0m:[38;5;10m[49m   `id` bigint NOT NULL AUTO_INCREMENT,
[0m[49m[38;5;10m+    323[0m:[38;5;10m[49m   `team_id` bigint NOT NULL,
[0m[49m[38;5;10m+    324[0m:[38;5;10m[49m   `user_name` varchar(100) NOT NULL,
[0m[49m[38;5;10m+    325[0m:[38;5;10m[49m   `role` enum('admin','editor','viewer') DEFAULT 'viewer',
[0m[49m[38;5;10m+    326[0m:[38;5;10m[49m   `created_at` datetime DEFAULT CURRENT_TIMESTAMP,
[0m[49m[38;5;10m+    327[0m:[38;5;10m[49m   PRIMARY KEY (`id`),
