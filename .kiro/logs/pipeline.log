text-blue-600 transition\"><i class=\"fa fa-database w-5 text-center\"></i><span>元数据</span></a>\n            <a href=\"/teams.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-users w-5 text-center\"></i><span>团队空间</span></a>\n        </div>\n    </nav>\n\n    <main class=\"ml-56 p-8\">\n        <div class=\"flex items-center justify-between mb-6\">\n            <div>\n                <h2 class=\"text-2xl font-bold text-gray-800\">Skill 市场</h2>\n                <p class=\"text-gray-500 mt-1\">浏览和分享提示词模板</p>\n            </div>\n            <button onclick=\"showCreateSkill()\" class=\"px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition\">\n                <i class=\"fa fa-plus mr-1\"></i>创建 Skill\n            </button>\n        </div>\n        <div id=\"skill-list\" class=\"grid grid-cols-8 gap-5\"></div>\n    </main>\n\n    <script src=\"/js/api.js\"></script>\n    <script src=\"/js/app.js\"></script>\n    <script src=\"/js/components.js\"></script>\n    <script>\n    async function loadSkills() {\n        $('#skill-list').html(components.loading());\n        try {\n            const data = await api.getSkillList();\n            if (!data.items.length) { $('#skill-list').html(components.emptyState('暂无 Skill')); return; }\n            let html = '';\n            data.items.forEach(item => {\n                html += `\n                <div class=\"col-span-2 bg-white rounded-xl p-5 border border-gray-100 card-hover\">\n                    <div class=\"flex items-center justify-between mb-3\">\n                        <span class=\"px-2 py-0.5 bg-purple-50 text-purple-500 rounded text-xs\">${item.category || '通用'}</span>\n                        <button onclick=\"api.toggleFavorite(${item.id}).then(loadSkills)\" class=\"text-gray-400 hover:text-red-500\"><i class=\"fa fa-heart-o\"></i></button>\n                    </div>\n                    <h3 class=\"font-semibold text-gray-800\">${item.name}</h3>\n                    <p class=\"text-sm text-gray-500 mt-1\">${truncate(item.description, 80)}</p>\n                    <div class=\"flex items-center gap-4 mt-3 text-xs text-gray-400\">\n                        <span><i class=\"fa fa-heart mr-1\"></i>${item.favorite_count || 0}</span>\n                        <span><i class=\"fa fa-play mr-1\"></i>${item.use_count || 0}</span>\n                    </div>\n                </div>`;\n            });\n            $('#skill-list').html(html);\n        } catch(e) { $('#skill-list').html(components.emptyState('加载失败')); }\n    }\n\n    function showCreateSkill() {\n        components.modal('创建 Skill', `\n            <input id=\"m-name\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" placeholder=\"Skill 名称\">\n            <input id=\"m-desc\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" placeholder=\"描述\">\n            <textarea id=\"m-prompt\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" rows=\"4\" placeholder=\"提示词模板\"></textarea>\n            <input id=\"m-cat\" class=\"w-full px-3 py-2 border rounded-lg\" placeholder=\"分类\">\n        `, async () => {\n            await api.createSkill({ name: $('#m-name').val(), description: $('#m-desc').val(), prompt_template: $('#m-prompt').val(), category: $('#m-cat').val() });\n            components.toast('创建成功', 'success');\n            loadSkills();\n        });\n    }\n\n    $(function() { loadSkills(); });\n    </script>\n</body>\n</html>\n",
