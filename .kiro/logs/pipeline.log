blue-600 transition\"><i class=\"fa fa-database w-5 text-center\"></i><span>元数据</span></a>\n            <a href=\"/teams.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-users w-5 text-center\"></i><span>团队空间</span></a>\n        </div>\n    </nav>\n\n    <main class=\"ml-56 p-8\">\n        <div class=\"flex items-center justify-between mb-6\">\n            <div>\n                <h2 class=\"text-2xl font-bold text-gray-800\">数据库元数据</h2>\n                <p class=\"text-gray-500 mt-1\">浏览和管理数据库表结构</p>\n            </div>\n            <button onclick=\"showImport()\" class=\"px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition\">\n                <i class=\"fa fa-download mr-1\"></i>导入元数据\n            </button>\n        </div>\n\n        <div class=\"grid grid-cols-8 gap-5\">\n            <div id=\"table-list\" class=\"col-span-3 bg-white rounded-xl p-5 border border-gray-100 max-h-[70vh] overflow-y-auto\"></div>\n            <div id=\"table-detail\" class=\"col-span-5 bg-white rounded-xl p-5 border border-gray-100\">\n                <div class=\"text-center py-16 text-gray-400\"><i class=\"fa fa-hand-pointer-o text-3xl mb-3\"></i><p>选择左侧表查看详情</p></div>\n            </div>\n        </div>\n    </main>\n\n    <script src=\"/js/api.js\"></script>\n    <script src=\"/js/app.js\"></script>\n    <script src=\"/js/components.js\"></script>\n    <script>\n    async function loadTables() {\n        try {\n            const data = await api.getTableList();\n            if (!data.items.length) { $('#table-list').html(components.emptyState('暂无表数据')); return; }\n            let html = '<div class=\"space-y-2\">';\n            data.items.forEach(t => {\n                html += `<div onclick=\"showTable('${t.table_name}')\" class=\"p-3 rounded-lg hover:bg-blue-50 cursor-pointer transition\">\n                    <div class=\"font-mono text-sm font-semibold text-gray-700\">${t.table_name}</div>\n                    <div class=\"text-xs text-gray-400 mt-1\">${t.table_comment || ''}</div>\n                </div>`;\n            });\n            html += '</div>';\n            $('#table-list').html(html);\n        } catch(e) { $('#table-list').html(components.emptyState('加载失败')); }\n    }\n\n    async function showTable(name) {\n        const data = await api.getTable(name);\n        let html = `<h3 class=\"font-semibold text-lg text-gray-800 mb-1\">${data.table_name}</h3>\n            <p class=\"text-sm text-gray-500 mb-4\">${data.table_comment || ''}</p>\n            <table class=\"w-full text-sm\"><thead><tr class=\"border-b text-left text-gray-500\">\n                <th class=\"py-2\">字段名</th><th>类型</th><th>说明</th></tr></thead><tbody>`;\n        data.columns.forEach(c => {\n            html += `<tr class=\"border-b border-gray-50\"><td class=\"py-2 font-mono\">${c.name}</td><td class=\"text-gray-500\">${c.type}</td><td class=\"text-gray-400\">${c.comment || ''}</td></tr>`;\n        });\n        html += '</tbody></table>';\n        $('#table-detail').html(html);\n    }\n\n    function showImport() {\n        components.modal('导入元数据', `<input id=\"m-dbname\" class=\"w-full px-3 py-2 border rounded-lg\" placeholder=\"数据库名称\" value=\"knowledge\">`, async () => {\n            const res = await api.importMetadata($('#m-dbname').val());\n            components.toast(`导入成功：${res.imported} 条`, 'success');\n            loadTables();\n        });\n    }\n\n    $(function() { loadTables(); });\n    </script>\n</body>\n</html>\n",
