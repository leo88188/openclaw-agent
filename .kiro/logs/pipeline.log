 ⋮    "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>智能搜索 - Knowledge</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css\" rel=\"stylesheet\">\n    <script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>\n    <link rel=\"stylesheet\" href=\"/css/custom.css\">\n</head>\n<body class=\"bg-gray-50 min-h-screen\">\n    <nav class=\"fixed left-0 top-0 h-full w-56 bg-white border-r border-gray-200 z-40 flex flex-col\">\n        <div class=\"p-5 border-b border-gray-100\">\n            <h1 class=\"text-xl font-bold text-blue-600\"><i class=\"fa fa-brain mr-2\"></i>Knowledge</h1>\n            <p class=\"text-xs text-gray-400 mt-1\">AI 知识库管理平台</p>\n        </div>\n        <div class=\"flex-1 py-4 space-y-1 px-3\">\n            <a href=\"/\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-dashboard w-5 text-center\"></i><span>仪表盘</span></a>\n            <a href=\"/knowledge.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-book w-5 text-center\"></i><span>知识管理</span></a>\n            <a href=\"/search.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-search w-5 text-center\"></i><span>智能搜索</span></a>\n            <a href=\"/skills.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-magic w-5 text-center\"></i><span>Skill 市场</span></a>\n            <a href=\"/metadata.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-database w-5 text-center\"></i><span>元数据</span></a>\n            <a href=\"/teams.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-users w-5 text-center\"></i><span>团队空间</span></a>\n        </div>\n    </nav>\n\n    <main class=\"ml-56 p-8\">\n        <div class=\"mb-6\">\n            <h2 class=\"text-2xl font-bold text-gray-800\">智能搜索</h2>\n            <p class=\"text-gray-500 mt-1\">语义化搜索知识库内容</p>\n        </div>\n\n        <div class=\"bg-white rounded-xl p-6 border border-gray-100 mb-6\">\n            <div class=\"flex gap-3\">\n                <input id=\"search-input\" class=\"flex-1 px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:border-blue-400 text-lg\" placeholder=\"输入关键词或自然语言搜索...\">\n                <button onclick=\"doSearch()\" class=\"px-6 py-3 bg-blue-500 text-white rounded-xl hover:bg-blue-600 transition\">\n                    <i class=\"fa fa-search mr-1\"></i>搜索\n                </button>\n            </div>\n        </div>\n\n        <div id=\"search-results\" class=\"grid grid-cols-8 gap-5\"></div>\n    </main>\n\n    <script src=\"/js/api.js\"></script>\n    <script src=\"/js/app.js\"></script>\n    <script src=\"/js/components.js\"></script>\n    <script>\n    async function doSearch() {\n        const q = $('#search-input').val().trim();\n        if (!q) return;\n        $('#search-results').html(components.loading());\n        try {\n            const data = await api.search(q);\n            if (!data.items.length) { $('#search-results').html(components.emptyState('未找到相关结果')); return; }\n            let html = '';\n            data.items.forEach(item => {\n                html += `\n                <div class=\"col-span-4 bg-white rounded-xl p-5 border border-gray-100 card-hover animate-fade-in\">\n                    <h3 class=\"font-semibold text-gray-800\">${item.title}</h3>\n                    <p class=\"text-sm text-gray-500 mt-2\">${truncate(item.content, 200)}</p>\n                    <div class=\"flex items-center gap-3 mt-3 text-xs text-gray-400\">\n                        ${item.category ? '<span class=\"px-2 py-0.5 bg-blue-50 text-blue-500 rounded\">' + item.category + '</span>' : ''}\n                        <span><i class=\"fa fa-clock-o mr-1\"></i>${formatDate(item.created_at)}</span>\n                    </div>\n                </div>`;\n            });\n            $('#search-results').html(html);\n        } catch(e) { $('#search-results').html(components.emptyState('搜索失败')); }\n    }\n\n    $('#search-input').on('keypress', function(e) { if (e.which === 13) doSearch(); });\n    </script>\n</body>\n</html>\n",
