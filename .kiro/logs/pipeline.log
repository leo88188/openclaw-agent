       </a>\n            <a href=\"/metadata.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\">\n                <i class=\"fa fa-database w-5 text-center\"></i><span>元数据</span>\n            </a>\n            <a href=\"/teams.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\">\n                <i class=\"fa fa-users w-5 text-center\"></i><span>团队空间</span>\n            </a>\n        </div>\n    </nav>\n\n    <!-- 主内容 -->\n    <main class=\"ml-56 p-8\">\n        <div class=\"mb-8\">\n            <h2 class=\"text-2xl font-bold text-gray-800\">仪表盘</h2>\n            <p class=\"text-gray-500 mt-1\">知识库概览与快捷操作</p>\n        </div>\n\n        <!-- 统计卡片 -->\n        <div class=\"grid grid-cols-8 gap-5 mb-8\">\n            <div class=\"col-span-2 bg-white rounded-xl p-5 border border-gray-100 card-hover animate-pulse-soft\">\n                <div class=\"flex items-center justify-between\">\n                    <div>\n                        <p class=\"text-sm text-gray-500\">知识条目</p>\n                        <p id=\"stat-knowledge\" class=\"text-3xl font-bold text-gray-800 mt-1\">-</p>\n                    </div>\n                    <div class=\"w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center\">\n                        <i class=\"fa fa-book text-blue-500 text-xl\"></i>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-span-2 bg-white rounded-xl p-5 border border-gray-100 card-hover animate-breathe\">\n                <div class=\"flex items-center justify-between\">\n                    <div>\n                        <p class=\"text-sm text-gray-500\">Skill 模板</p>\n                        <p id=\"stat-skills\" class=\"text-3xl font-bold text-gray-800 mt-1\">-</p>\n                    </div>\n                    <div class=\"w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center\">\n                        <i class=\"fa fa-magic text-green-500 text-xl\"></i>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-span-2 bg-white rounded-xl p-5 border border-gray-100 card-hover animate-swing\">\n                <div class=\"flex items-center justify-between\">\n                    <div>\n                        <p class=\"text-sm text-gray-500\">数据表</p>\n                        <p id=\"stat-tables\" class=\"text-3xl font-bold text-gray-800 mt-1\">-</p>\n                    </div>\n                    <div class=\"w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center\">\n                        <i class=\"fa fa-database text-purple-500 text-xl\"></i>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-span-2 bg-white rounded-xl p-5 border border-gray-100 card-hover\">\n                <div class=\"flex items-center justify-between\">\n                    <div>\n                        <p class=\"text-sm text-gray-500\">系统状态</p>\n                        <p class=\"text-lg font-bold text-green-500 mt-1\"><i class=\"fa fa-circle text-xs mr-1\"></i>运行中</p>\n                    </div>\n                    <div class=\"w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center\">\n                        <i class=\"fa fa-heartbeat text-green-500 text-xl\"></i>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 快捷操作 -->\n        <div class=\"grid grid-cols-8 gap-5\">\n            <div class=\"col-span-4 bg-white rounded-xl p-6 border border-gray-100\">\n                <h3 class=\"font-semibold text-gray-700 mb-4\"><i class=\"fa fa-bolt text-yellow-500 mr-2\"></i>快捷操作</h3>\n                <div class=\"grid grid-cols-2 gap-3\">\n                    <a href=\"/knowledge.html\" class=\"flex items-center gap-3 p-3 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 transition\">\n                        <i class=\"fa fa-plus-circle\"></i><span>新建知识</span>\n                    </a>\n                    <a href=\"/search.html\" class=\"flex items-center gap-3 p-3 rounded-lg bg-green-50 text-green-600 hover:bg-green-100 transition\">\n                        <i class=\"fa fa-search\"></i><span>搜索知识</span>\n                    </a>\n                    <a href=\"/skills.html\" class=\"flex items-center gap-3 p-3 rounded-lg bg-purple-50 text-purple-600 hover:bg-purple-100 transition\">\n                        <i class=\"fa fa-magic\"></i><span>浏览 Skill</span>\n                    </a>\n                    <a href=\"/metadata.html\" class=\"flex items-center gap-3 p-3 rounded-lg bg-orange-50 text-orange-600 hover:bg-orange-100 transition\">\n                        <i class=\"fa fa-database\"></i><span>导入元数据</span>\n                    </a>\n                </div>\n            </div>\n            <div class=\"col-span-4 bg-white rounded-xl p-6 border border-gray-100\">\n                <h3 class=\"font-semibold text-gray-700 mb-4\"><i class=\"fa fa-info-circle text-blue-500 mr-2\"></i>系统信息</h3>\n                <div class=\"space-y-3 text-sm text-gray-600\">\n                    <div class=\"flex justify-between\"><span>平台版本</span><span class=\"font-mono\">v1.0.0</span></div>\n                    <div class=\"flex justify-between\"><span>后端框架</span><span>FastAPI + MySQL + Redis</span></div>\n                    <div class=\"flex justify-between\"><span>向量引擎</span><span>内置 (可扩展)</span></div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    <script src=\"/js/api.js\"></script>\n    <script src=\"/js/app.js\"></script>\n    <script src=\"/js/components.js\"></script>\n    <script>\n    $(async function() {\n        try {\n            const stats = await api.getStats();\n            $('#stat-knowledge').text(stats.knowledge_count);\n            $('#stat-skills').text(stats.skill_count);\n            $('#stat-tables').text(stats.table_count);\n        } catch(e) {\n            console.log('Stats API not available yet');\n        }\n    });\n    </script>\n</body>\n</html>\n",
