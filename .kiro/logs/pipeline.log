in rows:\n        db.add(DbMetadata(\n            db_name=body.db_name, table_name=r[0], column_name=r[1],\n            column_type=r[2], column_comment=r[3], table_comment=r[4],\n        ))\n        count += 1\n    await db.commit()\n    return {\"ok\": True, \"imported\": count}\n",
