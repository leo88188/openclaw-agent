 ⋮    "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>知识管理 - Knowledge</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css\" rel=\"stylesheet\">\n    <script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>\n    <link rel=\"stylesheet\" href=\"/css/custom.css\">\n</head>\n<body class=\"bg-gray-50 min-h-screen\">\n    <nav class=\"fixed left-0 top-0 h-full w-56 bg-white border-r border-gray-200 z-40 flex flex-col\">\n        <div class=\"p-5 border-b border-gray-100\">\n            <h1 class=\"text-xl font-bold text-blue-600\"><i class=\"fa fa-brain mr-2\"></i>Knowledge</h1>\n            <p class=\"text-xs text-gray-400 mt-1\">AI 知识库管理平台</p>\n        </div>\n        <div class=\"flex-1 py-4 space-y-1 px-3\">\n            <a href=\"/\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-dashboard w-5 text-center\"></i><span>仪表盘</span></a>\n            <a href=\"/knowledge.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-book w-5 text-center\"></i><span>知识管理</span></a>\n            <a href=\"/search.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-search w-5 text-center\"></i><span>智能搜索</span></a>\n            <a href=\"/skills.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-magic w-5 text-center\"></i><span>Skill 市场</span></a>\n            <a href=\"/metadata.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-database w-5 text-center\"></i><span>元数据</span></a>\n            <a href=\"/teams.html\" class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition\"><i class=\"fa fa-users w-5 text-center\"></i><span>团队空间</span></a>\n        </div>\n    </nav>\n\n    <main class=\"ml-56 p-8\">\n        <div class=\"flex items-center justify-between mb-6\">\n            <div>\n                <h2 class=\"text-2xl font-bold text-gray-800\">知识管理</h2>\n                <p class=\"text-gray-500 mt-1\">管理团队知识条目</p>\n            </div>\n            <button onclick=\"showCreateModal()\" class=\"px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition\">\n                <i class=\"fa fa-plus mr-1\"></i>新建知识\n            </button>\n        </div>\n\n        <div id=\"knowledge-list\" class=\"grid grid-cols-8 gap-5\"></div>\n        <div id=\"pagination\"></div>\n    </main>\n\n    <script src=\"/js/api.js\"></script>\n    <script src=\"/js/app.js\"></script>\n    <script src=\"/js/components.js\"></script>\n    <script>\n    let currentPage = 1;\n\n    async function loadList(page) {\n        currentPage = page || 1;\n        $('#knowledge-list').html(components.loading());\n        try {\n            const data = await api.getKnowledgeList(currentPage);\n            if (!data.items.length) { $('#knowledge-list').html(components.emptyState('暂无知识条目')); return; }\n            let html = '';\n            data.items.forEach(item => {\n                html += `\n                <div class=\"col-span-4 bg-white rounded-xl p-5 border border-gray-100 card-hover\">\n                    <div class=\"flex items-start justify-between\">\n                        <h3 class=\"font-semibold text-gray-800\">${item.title}</h3>\n                        <div class=\"flex gap-2\">\n                            <button onclick=\"editItem(${item.id})\" class=\"text-gray-400 hover:text-blue-500\"><i class=\"fa fa-edit\"></i></button>\n                            <button onclick=\"deleteItem(${item.id})\" class=\"text-gray-400 hover:text-red-500\"><i class=\"fa fa-trash\"></i></button>\n                        </div>\n                    </div>\n                    <p class=\"text-sm text-gray-500 mt-2\">${truncate(item.content, 120)}</p>\n                    <div class=\"flex items-center gap-3 mt-3 text-xs text-gray-400\">\n                        ${item.category ? '<span class=\"px-2 py-0.5 bg-blue-50 text-blue-500 rounded\">' + item.category + '</span>' : ''}\n                        <span><i class=\"fa fa-clock-o mr-1\"></i>${formatDate(item.created_at)}</span>\n                    </div>\n                </div>`;\n            });\n            $('#knowledge-list').html(html);\n        } catch(e) { $('#knowledge-list').html(components.emptyState('加载失败')); }\n    }\n\n    function showCreateModal() {\n        components.modal('新建知识', `\n            <input id=\"m-title\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" placeholder=\"标题\">\n            <textarea id=\"m-content\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" rows=\"5\" placeholder=\"内容（支持Markdown）\"></textarea>\n            <input id=\"m-category\" class=\"w-full px-3 py-2 border rounded-lg\" placeholder=\"分类\">\n        `, async () => {\n            await api.createKnowledge({ title: $('#m-title').val(), content: $('#m-content').val(), category: $('#m-category').val() });\n            components.toast('创建成功', 'success');\n            loadList();\n        });\n    }\n\n    async function deleteItem(id) {\n        if (!confirm('确认删除？')) return;\n        await api.deleteKnowledge(id);\n        components.toast('已删除', 'success');\n        loadList();\n    }\n\n    async function editItem(id) {\n        const item = await api.getKnowledge(id);\n        components.modal('编辑知识', `\n            <input id=\"m-title\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" value=\"${item.title}\">\n            <textarea id=\"m-content\" class=\"w-full px-3 py-2 border rounded-lg mb-3\" rows=\"5\">${item.content}</textarea>\n            <input id=\"m-category\" class=\"w-full px-3 py-2 border rounded-lg\" value=\"${item.category || ''}\">\n        `, async () => {\n            await api.updateKnowledge(id, { title: $('#m-title').val(), content: $('#m-content').val(), category: $('#m-category').val() });\n            components.toast('更新成功', 'success');\n            loadList();\n        });\n    }\n\n    $(function() { loadList(); });\n    </script>\n</body>\n</html>\n",
