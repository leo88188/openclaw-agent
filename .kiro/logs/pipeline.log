 â‹®    "content": "/**\n * é€ڑç”¨ç»„ن»¶\n */\nconst components = {\n    toast(msg, type = 'info') {\n        const colors = { info: 'bg-blue-500', success: 'bg-green-500', error: 'bg-red-500' };\n        const el = $(`<div class=\"fixed top-4 right-4 ${colors[type]} text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-fade-in\">${msg}</div>`);\n        $('body').append(el);\n        setTimeout(() => el.remove(), 3000);\n    },\n\n    modal(title, content, onConfirm) {\n        const html = `\n        <div id=\"modal-overlay\" class=\"fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50\">\n            <div class=\"bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4 p-6\">\n                <h3 class=\"text-lg font-semibold mb-4\">${title}</h3>\n                <div class=\"mb-6\">${content}</div>\n                <div class=\"flex justify-end gap-3\">\n                    <button class=\"btn-cancel px-4 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50\">هڈ–و¶ˆ</button>\n                    <button class=\"btn-confirm px-4 py-2 rounded-lg bg-blue-500 text-white hover:bg-blue-600\">ç،®è®¤</button>\n                </div>\n            </div>\n        </div>`;\n        $('body').append(html);\n        $('#modal-overlay .btn-cancel').click(() => $('#modal-overlay').remove());\n        $('#modal-overlay .btn-confirm').click(() => { onConfirm(); $('#modal-overlay').remove(); });\n    },\n\n    pagination(total, page, size, onChange) {\n        const pages = Math.ceil(total / size);\n        if (pages <= 1) return '';\n        let html = '<div class=\"flex items-center gap-2 mt-6 justify-center\">';\n        for (let i = 1; i <= pages; i++) {\n            const active = i === page ? 'bg-blue-500 text-white' : 'bg-white text-gray-700 hover:bg-gray-100';\n            html += `<button onclick=\"${onChange}(${i})\" class=\"px-3 py-1 rounded-lg border ${active}\">${i}</button>`;\n        }\n        html += '</div>';\n        return html;\n    },\n\n    emptyState(msg = 'وڑ‚و— و•°وچ®') {\n        return `<div class=\"text-center py-16 text-gray-400\"><i class=\"fa fa-inbox text-4xl mb-3\"></i><p>${msg}</p></div>`;\n    },\n\n    loading() {\n        return '<div class=\"text-center py-16\"><i class=\"fa fa-spinner fa-spin text-3xl text-blue-400\"></i></div>';\n    }\n};\n",
